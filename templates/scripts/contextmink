#!/usr/bin/env bash
set -euo pipefail

# Thin launcher for the contextmink transcript guard. It execs a prebuilt
# release binary so repeated agent invocations do not pay cargo's per-call
# overhead, and rebuilds only when the binary is missing or older than sources.

root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
tool="$root/tools/contextmink"

if [[ ! -f "$tool/Cargo.toml" ]]; then
  echo "contextmink Cargo.toml not found at $tool" >&2
  exit 2
fi

exe=""
case "${OS:-}:$(uname -s 2>/dev/null || true)" in
  Windows_NT:* | *:MINGW* | *:MSYS* | *:CYGWIN*)
    exe=".exe"
    ;;
esac

bin="$tool/target/release/contextmink$exe"
if [[ ! -f "$bin" && -f "$tool/target/release/contextmink.exe" ]]; then
  bin="$tool/target/release/contextmink.exe"
elif [[ ! -f "$bin" && -f "$tool/target/release/contextmink" ]]; then
  bin="$tool/target/release/contextmink"
fi

needs_build=0
if [[ ! -f "$bin" ]]; then
  needs_build=1
elif [[ -n "$(find "$tool/src" "$tool/Cargo.lock" -newer "$bin" -print -quit 2>/dev/null)" ]]; then
  needs_build=1
elif [[ -n "$(find "$tool/Cargo.toml" -newer "$bin" -print -quit 2>/dev/null)" ]] && command -v cargo >/dev/null 2>&1; then
  needs_build=1
fi

if [[ "$needs_build" -eq 1 ]]; then
  if ! command -v cargo >/dev/null 2>&1; then
    if [[ -f "$bin" ]]; then
      echo "contextmink: Cargo is not on PATH; using existing release binary at $bin" >&2
    else
      echo "contextmink: Cargo is required to build $tool, but was not found on PATH" >&2
      exit 2
    fi
  else
    cargo build --quiet --release --manifest-path "$tool/Cargo.toml" 1>&2
  fi
fi

case "${OS:-}:$(uname -s 2>/dev/null || true)" in
  Windows_NT:* | *:MINGW* | *:MSYS* | *:CYGWIN*)
    if command -v bash >/dev/null 2>&1; then
      bash_path="$(command -v bash)"
      if command -v cygpath >/dev/null 2>&1; then
        bash_path="$(cygpath -w "$bash_path")"
      fi
      export CONTEXTMINK_BASH="$bash_path"
    fi
    # JSON Pointer selectors begin with '/', which MSYS would otherwise
    # rewrite as Windows paths when launching the native contextmink.exe.
    conv_excl=()
    next_selector=0
    for arg in "$@"; do
      if [[ "$next_selector" -eq 1 ]]; then
        case "$arg" in
          /*) conv_excl+=("$arg") ;;
        esac
        next_selector=0
        continue
      fi
      case "$arg" in
        --array | --field)
          next_selector=1
          ;;
        --array=/* | --field=/*)
          conv_excl+=("$arg")
          ;;
      esac
    done
    if [[ "${#conv_excl[@]}" -gt 0 ]]; then
      joined="$(IFS=';'; printf '%s' "${conv_excl[*]}")"
      if [[ -n "${MSYS2_ARG_CONV_EXCL:-}" ]]; then
        export MSYS2_ARG_CONV_EXCL="${MSYS2_ARG_CONV_EXCL};${joined}"
      else
        export MSYS2_ARG_CONV_EXCL="$joined"
      fi
    fi
    ;;
esac

exec "$bin" "$@"
